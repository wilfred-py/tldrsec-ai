// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model represents application users
model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String?
  authProvider   String // "google", "github", "twitter"
  authProviderId String // ID from provider
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // User preferences
  notificationPreference String @default("immediate") // "immediate", "digest", "none"
  theme                  String @default("light") // "light", "dark"

  // Relationships
  tickers Ticker[]

  @@map("users")
}

// Ticker model represents stock ticker symbols tracked by users
model Ticker {
  id          String   @id @default(cuid())
  symbol      String // Stock ticker symbol
  companyName String // Full company name
  userId      String // Foreign key to User
  addedAt     DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relationships
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  summaries Summary[]

  @@unique([userId, symbol]) // One ticker per user
  @@index([symbol])
  @@map("tickers")
}

// Summary model represents SEC filing summaries
model Summary {
  id          String   @id @default(cuid())
  tickerId    String // Foreign key to Ticker
  filingType  String // "10-K", "10-Q", "8-K", "Form4"
  filingDate  DateTime
  filingUrl   String // Link to original filing
  summaryText String   @db.Text // Full summary text
  summaryJSON Json? // Structured summary data
  createdAt   DateTime @default(now())
  sentToUser  Boolean  @default(false) // Whether notification was sent

  // Relationships
  ticker Ticker @relation(fields: [tickerId], references: [id], onDelete: Cascade)

  @@index([filingDate])
  @@index([filingType])
  @@map("summaries")
}
