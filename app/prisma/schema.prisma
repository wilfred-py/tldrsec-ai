generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String   @id @default(cuid())
  email                  String   @unique
  name                   String?
  authProvider           String
  authProviderId         String
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  notificationPreference String   @default("immediate")
  theme                  String   @default("light")
  tickers                Ticker[]

  @@map("users")
}

model Ticker {
  id          String    @id @default(cuid())
  symbol      String
  companyName String
  userId      String
  addedAt     DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  summaries   Summary[]
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol])
  @@index([symbol])
  @@map("tickers")
}

model Summary {
  id          String   @id @default(cuid())
  tickerId    String
  filingType  String
  filingDate  DateTime
  filingUrl   String
  summaryText String
  summaryJSON Json?
  createdAt   DateTime @default(now())
  sentToUser  Boolean  @default(false)
  ticker      Ticker   @relation(fields: [tickerId], references: [id], onDelete: Cascade)

  @@index([filingDate])
  @@index([filingType])
  @@map("summaries")
}
